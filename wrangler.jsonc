{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "homotechsualdocs",
  "main": "cloudflare/worker.js",
  "compatibility_date": "2026-04-20",
  "assets": {
    "binding": "ASSETS",
    "directory": "./build",
    "html_handling": "auto-trailing-slash",
    "not_found_handling": "404-page"
  },
  "observability": {
    "enabled": true
  }
}